# ============================================================
# Browser Agent – Environment Variables Reference
# ============================================================
# Copy this file to .env.local for local overrides (not committed to git).
# For CI/production, set these via GitHub Actions secrets or shell env.
#
# Priority (highest → lowest):
#   shell env  >  .env.local  >  .env.production  >  .env
# ============================================================

# Base URL for the remote frontend bundle CDN.
# The Electron app will fetch version.json from this URL on startup
# to check for and download frontend updates.
# Leave empty to disable remote updates entirely.
# Example: https://cdn.example.com/browser-agent/frontend
FRONTEND_BUNDLE_URL=
