{
  "name": "electron-browser-agent",
  "version": "0.1.0",
  "description": "Electron desktop app wrapping Mastra + Playwright MCP browser agent",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --fix .",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "pnpm@10.29.3",
  "dependencies": {
    "@ai-sdk/react": "^3.0.143",
    "@mastra/ai-sdk": "^1.2.1",
    "@mastra/core": "^1.17.0",
    "@mastra/libsql": "^1.7.2",
    "@mastra/loggers": "^1.0.3",
    "@mastra/mcp": "^1.3.1",
    "@mastra/memory": "^1.10.0",
    "@playwright/mcp": "^0.0.68",
    "ai": "^6.0.141",
    "electron-store": "^11.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --fix --no-errors-on-unmatched",
      "biome format --fix --no-errors-on-unmatched"
    ],
    "*.{json,css}": [
      "biome format --fix --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.27",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}