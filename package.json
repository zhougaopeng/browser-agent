{
  "name": "browser-agent-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,electron \"pnpm -F @browser-agent/web dev\" \"wait-on http://localhost:5173 && pnpm -F @browser-agent/electron dev\"",
    "dev:server": "pnpm -F @browser-agent/server dev",
    "dev:web": "pnpm -F @browser-agent/web dev",
    "build": "pnpm -F @browser-agent/server build && pnpm -F @browser-agent/web build",
    "build:server": "pnpm -F @browser-agent/server build",
    "build:web": "pnpm -F @browser-agent/web build",
    "build:electron": "pnpm -F @browser-agent/electron build",
    "package": "pnpm -F @browser-agent/web build:zip && pnpm -F @browser-agent/electron fetch-frontend --local ../web/dist && pnpm -F @browser-agent/electron package",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --fix .",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "pnpm@10.29.3",
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --fix --no-errors-on-unmatched",
      "biome format --fix --no-errors-on-unmatched"
    ],
    "*.{json,css}": [
      "biome format --fix --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "vitest": "^4.1.2",
    "wait-on": "^8.0.3"
  }
}