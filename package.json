    "@mastra/memory": "^1.10.0",
    "@playwright/mcp": "^0.0.68",
    "ai": "^4.0.0",
    "electron-store": "^10.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^22.0.0",
